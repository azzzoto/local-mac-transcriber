INPUT_DIR=input
OUTPUT_DIR=output
CONFIG_PATH=config.yaml
PROMPT_PROFILE=gastro_it
AUDIO_FILE=

WHISPER_MODEL=large-v3
WHISPER_LANGUAGE=it
CHUNK_MINUTES=30
KEEP_CHUNKS=true
OVERWRITE=false

OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TEMPERATURE=0.2
OLLAMA_TIMEOUT_SECONDS=600

LOG_LEVEL=INFO
AUDIO_EXTENSIONS=.aac,.m4a,.mp3,.mp4,.mpeg,.mpga,.wav,.webm